{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "env": {
        "NODE_ENV": "production",
        "API_URL": "http://hawkerfinalv-production.up.railway.app/api",
        "EXPO_PUBLIC_API_URL": "http://hawkerfinalv-production.up.railway.app/api"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "NODE_ENV": "production",
        "API_URL": "http://hawkerfinalv-production.up.railway.app/api",
        "EXPO_PUBLIC_API_URL": "http://hawkerfinalv-production.up.railway.app/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}